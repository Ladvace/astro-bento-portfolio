---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card/index.astro";
import IntroCard from "../components/IntroCard.astro";
import ContactsCard from "../components/ContactsCard.astro";
import ThemeChangeCard from "../components/ThemeChangeCard.astro";
import TimeZone from "../components/TimeZoneCard.astro";
import AboutMe from "../components/AboutMe.astro";
import Now from "../components/Now.astro";
import Globe from "../components/Globe";
import DesignWorksCard from "../components/DesignWorksCard.astro";
import PixelHeart from "../components/PixelHeart.astro";
import { SITE } from "../site-config";

---

<script>
  import { initHomeEntrance } from "../lib/home-entrance";

  initHomeEntrance();
</script>

<script>
  const CELL = 20;
  const TRAIL_LEN = 8;
  const TRAIL_OPACITY = [0.8, 0.6, 0.45, 0.3, 0.2, 0.12, 0.07, 0.03];
  let glowInterval: ReturnType<typeof setInterval> | null = null;

  function resetCell(c: HTMLElement) {
    c.style.background = "";
    c.style.opacity = "";
    c.style.transition = "";
  }

  function initPlaygroundGrid() {
    const container = document.getElementById("playground-grid");
    if (!container) return;

    const cols = Math.ceil(container.clientWidth / CELL);
    const rows = Math.ceil(container.clientHeight / CELL);
    const total = cols * rows;

    Object.assign(container.style, {
      display: "grid",
      gridTemplateColumns: `repeat(${cols}, ${CELL}px)`,
      gridTemplateRows: `repeat(${rows}, ${CELL}px)`,
    });
    container.innerHTML = "";

    for (let i = 0; i < total; i++) {
      const cell = document.createElement("div");
      cell.style.cssText = "border:1px solid rgba(255,255,255,0.06);transition:background 0.4s,opacity 0.4s;";
      container.appendChild(cell);
    }

    if (glowInterval) clearInterval(glowInterval);
    glowInterval = setInterval(() => {
      const cell = container.children[Math.floor(Math.random() * total)] as HTMLElement;
      if (!cell) return;
      cell.style.background = "var(--primary-500)";
      cell.style.opacity = "0.5";
      setTimeout(() => {
        cell.style.background = "";
        cell.style.opacity = "0.06";
        setTimeout(() => { cell.style.opacity = ""; }, 400);
      }, 600);
    }, 250);

    const cardEl = document.querySelector<HTMLElement>('a[href="playground"]')?.closest<HTMLElement>(".card");
    let trail: number[] = [];

    const applyTrail = () => trail.forEach((idx, i) => {
      const cell = container.children[idx] as HTMLElement;
      if (!cell) return;
      cell.style.transition = "none";
      cell.style.background = "var(--primary-500)";
      cell.style.opacity = String(TRAIL_OPACITY[i] ?? 0);
    });

    const clearTrail = () => {
      trail.forEach(idx => {
        const cell = container.children[idx] as HTMLElement;
        if (cell) { cell.style.transition = "opacity 0.1s"; cell.style.opacity = "0"; }
      });
      setTimeout(() => { trail.forEach(idx => { const c = container.children[idx] as HTMLElement; if (c) resetCell(c); }); trail = []; }, 100);
    };

    cardEl?.addEventListener("mousemove", (e: MouseEvent) => {
      if (!window.matchMedia("(pointer: fine)").matches) return;
      const rect = container.getBoundingClientRect();
      const idx = Math.floor((e.clientY - rect.top) / CELL) * cols + Math.floor((e.clientX - rect.left) / CELL);
      if (idx === trail[0] || idx < 0 || idx >= total) return;
      trail = [idx, ...trail.filter(i => i !== idx)];
      if (trail.length > TRAIL_LEN) {
        trail.splice(TRAIL_LEN).forEach(i => {
          const c = container.children[i] as HTMLElement;
          if (c) { c.style.transition = "opacity 0.1s"; c.style.opacity = "0"; setTimeout(() => resetCell(c), 100); }
        });
      }
      applyTrail();
    });

    cardEl?.addEventListener("mouseleave", clearTrail);
  }

  document.addEventListener("astro:page-load", initPlaygroundGrid);
  document.addEventListener("astro:before-swap", () => { if (glowInterval) clearInterval(glowInterval); });
</script>

<script>
  const GB_CELL = 20;
  let gbAnimId: number | null = null;

  function initGuestbookGrid() {
    const container = document.getElementById("guestbook-grid");
    if (!container) return;

    const cols = Math.ceil(container.clientWidth / GB_CELL);
    const rows = Math.ceil(container.clientHeight / GB_CELL);
    const total = cols * rows;

    Object.assign(container.style, {
      display: "grid",
      gridTemplateColumns: `repeat(${cols}, ${GB_CELL}px)`,
      gridTemplateRows: `repeat(${rows}, ${GB_CELL}px)`,
    });
    container.innerHTML = "";

    for (let i = 0; i < total; i++) {
      const cell = document.createElement("div");
      cell.style.cssText = "border-radius:50%;margin:3px;box-sizing:border-box;background:var(--primary-500);";
      container.appendChild(cell);
    }

    if (gbAnimId !== null) cancelAnimationFrame(gbAnimId);

    const animate = (t: number) => {
      const time = t * 0.001;
      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          const cell = container.children[y * cols + x] as HTMLElement;
          if (!cell) continue;
          // Two interfering cosine waves travelling in different directions
          const w1 = Math.cos(time * 1.1 + x * 0.9 + y * 0.6);
          const w2 = Math.cos(time * 0.7 - x * 0.5 + y * 1.1);
          const v = (w1 + w2) / 2; // range -1 to 1
          cell.style.opacity = (Math.max(0, (v + 1) / 2) * 0.45).toFixed(3);
        }
      }
      gbAnimId = requestAnimationFrame(animate);
    };

    gbAnimId = requestAnimationFrame(animate);
  }

  document.addEventListener("astro:page-load", initGuestbookGrid);
  document.addEventListener("astro:before-swap", () => { if (gbAnimId !== null) cancelAnimationFrame(gbAnimId); });
</script>

<Layout
  description={`I'm a developer based in ${SITE.location.countryName}, passionate about user experience and specializing in engaging animations and micro-interactions. My primary tools of choice include: JavaScript, React, Solid.js, Astro, Svelte, and Node.js.`}
  title={`${SITE.author.fullName} - ${SITE.author.jobTitle}`}
>
  <main
    class="text-white m-auto p-2 grid gap-2 max-w-6xl overflow-x-hidden relative w-full sm:p-4 sm:gap-2 md:grid-cols-2 md:gap-3 md:p-6 lg:h-[max(100dvh,700px)] lg:grid-rows-8 lg:grid-cols-4 lg:gap-4"
  >
    <IntroCard />
    <AboutMe />
    <ContactsCard />
    <TimeZone />
    <DesignWorksCard />
    <Now />
    <Card href="playground" colSpan="md:col-span-1" rowSpan="md:row-span-1">
      <div slot="background" class="absolute inset-0 -z-10 overflow-hidden">
        <div id="playground-grid" class="absolute inset-0"></div>
      </div>
      <div class="flex-1 flex items-center">
        <h2 class="text-xl md:text-2xl xl:text-xl font-bold m-0">Playground</h2>
      </div>
    </Card>
    <Card href="/guestbook" colSpan="md:col-span-1 w-full" rowSpan="md:row-span-1">
      <div slot="background" id="guestbook-grid" class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true"></div>
      <div class="flex-1 flex items-center">
        <h2 class="text-xl md:text-2xl xl:text-xl font-bold m-0">Guestbook</h2>
      </div>
    </Card>
    <Card href="/blog" colSpan="md:col-span-1" rowSpan="md:row-span-1">
      <div class="flex-1 flex items-center">
        <h2 class="text-xl md:text-2xl xl:text-xl font-bold m-0">Blog</h2>
      </div>
    </Card>
    <Card
      colSpan="md:col-span-1"
      href="travel"
      rowSpan="md:row-span-1"
      title="Countries I visited"
    >
      <div slot="background" class="absolute inset-0 -z-10">
        <div class="hidden md:block h-full w-full">
          <Globe client:media="(min-width: 768px)" />
        </div>
        <div class="block md:hidden h-full w-full">
          <Globe client:media="(max-width: 768px)" isStatic={true} />
        </div>
      </div>
      <span class="text-xs text-white/60">{SITE.visitedCountries.length} countries</span>
    </Card>
    <ThemeChangeCard />

    <Card colSpan="md:col-span-1" rowSpan="md:row-span-1">
      <div class="flex h-full items-center justify-center">
        <p class="text-[10px] whitespace-nowrap text-center">
          © {new Date().getFullYear()} · Crafted with <PixelHeart /> using <a class="text-red-500" href="https://astro.build/" target="_blank">Astro</a> by Me.
        </p>
      </div>
    </Card>
  </main>
</Layout>

