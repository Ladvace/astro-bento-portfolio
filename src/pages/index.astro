---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card/index.astro";
import IntroCard from "../components/IntroCard.astro";
import ContactsCard from "../components/ContactsCard.astro";
import ThemeChangeCard from "../components/ThemeChangeCard.astro";
import TimeZone from "../components/TimeZoneCard.astro";
import AboutMe from "../components/AboutMe.astro";
import Now from "../components/Now.astro";
import Globe from "../components/Globe";
import DesignWorksCard from "../components/DesignWorksCard.astro";
import { SITE } from "../site-config";

---

<script>
  import { initHomeEntrance } from "../lib/home-entrance";

  initHomeEntrance();
</script>

<Layout
  description={`I'm a developer based in ${SITE.location.countryName}, passionate about user experience and specializing in engaging animations and micro-interactions. My primary tools of choice include: JavaScript, React, Solid.js, Astro, Svelte, and Node.js.`}
  title={`${SITE.author.fullName} - ${SITE.author.jobTitle}`}
>
  <main
    class="text-white m-auto p-2 grid gap-2 max-w-6xl overflow-x-hidden relative w-full sm:p-4 sm:gap-2 md:grid-cols-2 md:gap-3 md:p-6 lg:h-[max(100dvh,700px)] lg:grid-rows-8 lg:grid-cols-4 lg:gap-4"
  >
    <IntroCard />
    <AboutMe />
    <ContactsCard />
    <TimeZone />
    <DesignWorksCard />
    <Now />
    <Card
      href="playground"
      colSpan="md:col-span-1"
      rowSpan="md:row-span-1"
      title="Playground"
    />
    <Card
      href="/guestbook"
      colSpan="md:col-span-1 w-full"
      rowSpan="md:row-span-1"
      title="Guestbook"
    />
    <Card
      href="/blog"
      colSpan="md:col-span-1"
      rowSpan="md:row-span-1"
      title="Blog"
    />
    <Card
      colSpan="md:col-span-1"
      href="travel"
      rowSpan="md:row-span-1"
      title="Countries I visited"
    >
      <div slot="background" class="absolute inset-0 -z-10">
        <div class="hidden md:block h-full w-full">
          <Globe client:media="(min-width: 768px)" />
        </div>
        <div class="block md:hidden h-full w-full">
          <Globe client:media="(max-width: 768px)" isStatic={true} />
        </div>
      </div>
      <span class="text-xs text-white/60">{SITE.visitedCountries.length} countries</span>
    </Card>
    <ThemeChangeCard />

    <Card colSpan="md:col-span-1" rowSpan="md:row-span-1">
      <div class="flex h-full items-center justify-center">
        <p class="text-[10px] whitespace-nowrap text-center">
          © {new Date().getFullYear()} · Crafted with ♥️ using <a
            class="text-red-500"
            href="https://astro.build/"
            target="_blank">Astro</a
          > by Me.
        </p>
      </div>
    </Card>
  </main>
</Layout>
