---
import Layout from "../../layouts/Layout.astro";
import LoaderAnimation from "../../components/LoaderAnimation.astro";
import BackLink from "../../components/BackLink.astro";
import Scroll1Component from "../../components/playground/scroll-1/scroll-1.svelte";
import { SITE } from "../../site-config";
---

<LoaderAnimation />

<Layout
  title={`${SITE.author.fullName} - Playground - Gsap future scroll`}
  description="Scroll animation made with GSAP and some custom futuristic svg"
  fullScreen="h-auto"
>
  <div class="flex flex-col px-4 pb-4 overscroll-none">
    <header class="sticky top-0 inset-x-0 z-60 p-4">
      <BackLink />
    </header>
    <div>
      <Scroll1Component client:load />
    </div>
  </div>
</Layout>
