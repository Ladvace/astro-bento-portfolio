---
import Layout from "../../layouts/Layout.astro";
import Rifle1Component from "../../components/playground/rifle-1";
import rifleRiv from "../../riveAnimations/rifle.riv";
import { SITE } from "../../site-config";
---

<link
  rel="preload"
  href={typeof rifleRiv === "string" ? rifleRiv : (rifleRiv as { src: string }).src}
  as="fetch"
  crossorigin="anonymous"
/>

<script>
  import { animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../../lib/constants";

  animate([loaderAnimation] as AnimationSequence);
</script>

<Layout
  title={`${SITE.author.fullName} - Playground - Rifle animation`}
  description="A rifle animation made with rive.app"
>
  <div class="flex flex-col items-start h-screen w-screen p-4">
    <a
      href="/playground"
      class="text-white bg-neutral-900 hover:bg-neutral-800 w-fit px-4 py-2 border-1 border-solid border-neutral-600 rounded-lg"
      >Back</a
    >

    <div class="w-full h-full flex justify-center items-center">
      <Rifle1Component client:load />
    </div>
  </div>
</Layout>
