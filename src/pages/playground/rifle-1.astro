---
import PlaygroundShell from "../../components/PlaygroundShell.astro";
import Rifle1Component from "../../components/playground/rifle-1";
import rifleRivUrl from "../../riveAnimations/rifle.riv?url";
import { SITE } from "../../site-config";
---

<link rel="preload" href={rifleRivUrl} as="fetch" crossorigin="anonymous" />

<PlaygroundShell
  title={`${SITE.author.fullName} - Playground - Rifle animation`}
  description="A rifle animation made with rive.app"
>
  <Rifle1Component client:load rivUrl={rifleRivUrl} />
</PlaygroundShell>
