---
import Layout from "../../layouts/Layout.astro";
import LoaderAnimation from "../../components/LoaderAnimation.astro";
import { WIPE_VARIANT_LIST } from "../../lib/constants-wipe";
import { SITE } from "../../site-config";

const defaultVariant = WIPE_VARIANT_LIST[0];
---

<LoaderAnimation />

<Layout
  title={`${SITE.author.fullName} - Playground - MorphSVG wipe`}
  description="Full-screen SVG path morph wipe with GSAP MorphSVGPlugin."
  fullScreen="h-auto"
>
  <div class="morph-wipe-page w-full self-stretch">
    <header class="morph-wipe-header">
      <a
        href="/playground"
        class="text-white bg-neutral-900 hover:bg-neutral-800 w-fit px-4 py-2 border border-solid border-neutral-600 rounded-lg"
        >Back</a
      >
    </header>

    <p class="hint">
      <strong>MorphSVG</strong>: full-screen overlay SVG. Pick a variant, then
      run the wipe.
    </p>
    <div class="variant-controls" role="radiogroup" aria-label="Wipe variant">
      {
        WIPE_VARIANT_LIST.map((v, i) => (
          <button
            type="button"
            class="morph-variant-btn"
            data-variant-id={v.id}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            {v.label}
          </button>
        ))
      }
    </div>

    <div class="controls">
      <button type="button" id="btn-wipe-in">Wipe in (cover)</button>
      <button type="button" id="btn-wipe-out">Wipe out (reveal)</button>
      <button type="button" id="btn-wipe-full">Full cycle</button>
    </div>

    <div class="transition__morph__svg" id="morph-overlay" aria-hidden="true">
      <svg viewBox="0 0 100 100" preserveAspectRatio="xMidYMin slice">
        <path
          id="morph-path"
          stroke="none"
          fill="none"
          stroke-width="2px"
          vector-effect="non-scaling-stroke"
          data-original-path={defaultVariant.collapsedBottom}></path>
      </svg>
    </div>
  </div>
</Layout>

<script>
  import gsap from "gsap";
  import MorphSVGPlugin from "gsap/MorphSVGPlugin";
  import type { WipeVariantPaths } from "../../lib/constants-wipe";
  import { WIPE_VARIANTS } from "../../lib/constants-wipe";

  function initMorphWipe() {
    gsap.registerPlugin(MorphSVGPlugin);

    const overlayMaybe = document.getElementById("morph-overlay");
    const pathMaybe = document.getElementById("morph-path");
    if (!overlayMaybe || !pathMaybe) return;

    const overlayRoot = overlayMaybe;
    const morphPath = pathMaybe;

    let playing = false;

    let activeVariant: WipeVariantPaths =
      WIPE_VARIANTS[pathMaybe.dataset.activeVariantId ?? "classic"] ??
      WIPE_VARIANTS.classic;

    function restPath() {
      return activeVariant.collapsedBottom;
    }

    function showMorphOverlay() {
      overlayRoot.classList.add("is-visible");
      gsap.set(overlayRoot, { autoAlpha: 1 });
    }

    function hideMorphOverlay() {
      overlayRoot.classList.remove("is-visible");
      gsap.set(overlayRoot, { autoAlpha: 0 });
    }

    function applyVariant(id: string) {
      if (playing) return;
      const next = WIPE_VARIANTS[id];
      if (!next) return;

      activeVariant = next;
      morphPath.dataset.activeVariantId = next.id;
      const collapsed = next.collapsedBottom;
      morphPath.dataset.originalPath = collapsed;
      gsap.set(morphPath, { attr: { d: collapsed } });

      for (const btn of variantButtons) {
        const pressed = btn.dataset.variantId === id;
        btn.setAttribute("aria-pressed", pressed ? "true" : "false");
      }
    }

    const btnIn = document.getElementById("btn-wipe-in");
    const btnOut = document.getElementById("btn-wipe-out");
    const btnFull = document.getElementById("btn-wipe-full");
    const variantButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".morph-variant-btn"),
    );
    const controlButtons = [btnIn, btnOut, btnFull].filter(
      (b): b is HTMLButtonElement => b instanceof HTMLButtonElement,
    );

    function setControlsBusy(busy: boolean) {
      for (const b of [...controlButtons, ...variantButtons]) {
        b.disabled = busy;
        b.setAttribute("aria-busy", busy ? "true" : "false");
      }
    }

    function timelineDone(tl: gsap.core.Timeline) {
      return new Promise<void>((resolve) => {
        tl.eventCallback("onComplete", resolve);
      });
    }

    function createLeaveTimeline() {
      const p = activeVariant;
      showMorphOverlay();
      gsap.set(morphPath, { attr: { d: p.collapsedBottom } });
      const tl = gsap.timeline({
        defaults: { duration: 0.5, ease: "sine.in" },
      });
      tl.to(morphPath, { morphSVG: p.enterFromBottom }).to(
        morphPath,
        { morphSVG: p.filledFromBottom, ease: "sine" },
        "<+=0.5",
      );
      return tl;
    }

    function createAfterTimeline() {
      const p = activeVariant;
      const tl = gsap.timeline({
        defaults: { duration: 0.5, ease: "sine.in" },
        onComplete: () => {
          hideMorphOverlay();
          gsap.set(morphPath, { attr: { d: restPath() } });
        },
      });
      gsap.set(morphPath, { attr: { d: p.filledFromBottom } });
      tl.to(morphPath, { morphSVG: p.leaveFromTop }).to(
        morphPath,
        { morphSVG: p.unfilledTop, ease: "sine" },
        "<+=0.5",
      );
      return tl;
    }

    async function runLeave() {
      if (playing) return;
      playing = true;
      setControlsBusy(true);
      try {
        await timelineDone(createLeaveTimeline());
      } finally {
        playing = false;
        setControlsBusy(false);
      }
    }

    async function runAfter() {
      if (playing) return;
      playing = true;
      setControlsBusy(true);
      try {
        await timelineDone(createAfterTimeline());
      } finally {
        playing = false;
        setControlsBusy(false);
      }
    }

    async function runFullCycle() {
      if (playing) return;
      playing = true;
      setControlsBusy(true);
      try {
        await timelineDone(createLeaveTimeline());
        await timelineDone(createAfterTimeline());
      } finally {
        playing = false;
        setControlsBusy(false);
      }
    }

    morphPath.dataset.activeVariantId = activeVariant.id;
    gsap.set(morphPath, { attr: { d: restPath() } });
    hideMorphOverlay();

    for (const btn of variantButtons) {
      btn.addEventListener("click", () => {
        const id = btn.dataset.variantId;
        if (id) applyVariant(id);
      });
    }

    btnIn?.addEventListener("click", () => runLeave());
    btnOut?.addEventListener("click", () => runAfter());
    btnFull?.addEventListener("click", () => runFullCycle());
  }

  initMorphWipe();
</script>

<style>
  .morph-wipe-page {
    box-sizing: border-box;
    margin: 0;
    min-height: 100vh;
    display: grid;
    place-items: center;
    gap: 1rem;
    padding: 1rem;
    padding-top: max(1rem, env(safe-area-inset-top));
    font-family: system-ui, sans-serif;
    background: #e8e4df;
    position: relative;
  }

  .morph-wipe-header {
    position: relative;
    z-index: 110;
    justify-self: start;
    align-self: start;
    width: 100%;
    margin-bottom: 0;
  }

  .morph-wipe-page *,
  .morph-wipe-page *::before,
  .morph-wipe-page *::after {
    box-sizing: border-box;
  }

  .hint {
    max-width: 40rem;
    font-size: 0.9rem;
    line-height: 1.45;
    color: #333;
    text-align: center;
    position: relative;
    z-index: 10001;
    margin: 0;
  }

  .variant-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 110;
  }

  .morph-variant-btn {
    padding: 0.4rem 0.65rem;
    border-radius: 999px;
    border: 1px solid #444;
    background: #fff;
    cursor: pointer;
    font: inherit;
    font-size: 0.85rem;
  }

  .morph-variant-btn:hover {
    background: #f3f3f3;
  }

  .morph-variant-btn[aria-pressed="true"] {
    background: #111;
    color: #fff;
    border-color: #111;
  }

  .controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    position: relative;
    z-index: 110;
  }

  .controls button {
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    border: 1px solid #111;
    background: #fff;
    cursor: pointer;
    font: inherit;
  }

  .controls button:hover {
    background: #f3f3f3;
  }

  .controls button:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .controls button:disabled:hover {
    background: #fff;
  }

  .morph-variant-btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .morph-variant-btn:disabled:hover {
    background: #fff;
  }

  .morph-variant-btn[aria-pressed="true"]:disabled {
    background: #111;
    color: #fff;
    opacity: 0.55;
  }

  .transition__morph__svg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100dvh;
    pointer-events: none;
    visibility: hidden;
    z-index: 100;
    isolation: isolate;
  }

  .transition__morph__svg.is-visible {
    visibility: visible;
    pointer-events: auto;
  }

  .transition__morph__svg svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .transition__morph__svg svg path {
    fill: #111;
    stroke: #111;
  }
</style>
