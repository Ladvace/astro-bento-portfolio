---
import BasicLayout from "./BasicLayout.astro";

interface Props {
  title: string;
  description: string;
  page?: "travel";
  fullScreen?: string;
  hideSoundToggle?: boolean;
  hideCal?: boolean;
}

const { title, description, hideSoundToggle, hideCal } = Astro.props;
---

<BasicLayout
  description={description}
  title={title}
  hideSoundToggle={hideSoundToggle}
  hideCal={hideCal}
>
  <slot />
</BasicLayout>
