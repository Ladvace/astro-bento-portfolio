---
import "../style.css";
import { ClientRouter } from "astro:transitions";
import { LINKS } from "../lib/constants";
import { SITE } from "../site-config";

interface Props {
  title: string;
  description: string;
  page?: "travel" | "blog";
  slug?: string | undefined;
  pubDate?: string;
}

const { title, description, page, pubDate } = Astro.props;
const image = `${Astro.url.origin}/og-image.png`;

const schema =
  page !== "blog"
    ? {
        "@context": "https://schema.org",
        "@type": "Person",
        name: SITE.author.fullName,
        url: Astro.url.origin,
        sameAs: [LINKS.linkedin, LINKS.github],
        image: `${Astro.url.origin}/og-image.png`,
        jobTitle: SITE.author.jobTitle,
        knowsAbout: ["JavaScript", "React", "Astro", "Solid.js", "Svelte", "Node.js", "User Experience", "Web Development"],
        worksFor: {
          "@type": "Organization",
          name: "Self-Employed",
          address: {
            "@type": "PostalAddress",
            addressLocality: SITE.location.countryName,
            addressCountry: SITE.location.countryCode,
          },
        },
        nationality: {
          "@type": "Country",
          name: SITE.location.countryName,
        },
      }
    : {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": Astro.url.href,
        },
        headline: title || title,
        description: description || title,
        image: `${Astro.url.origin}/og-image.png`, //TODO: dynamic
        author: {
          "@type": "Person",
          name: SITE.author.shortName,
          url: Astro.url.origin,
          sameAs: [LINKS.linkedin, LINKS.github],
        },
        publisher: {
          "@type": "Organization",
          name: SITE.author.shortName,
          logo: {
            "@type": "ImageObject",
            url: `${Astro.url.origin}/og-image.png`,
          },
        },
        datePublished: pubDate || new Date().toISOString(),
        dateModified: pubDate || new Date().toISOString(),
      };
---

<!doctype html>
<html
  lang="en"
  data-cal-namespace={SITE.cal.durationNamespace}
  data-cal-origin={SITE.cal.origin}
>
  <head>
    <meta charset="UTF-8" />
    <ClientRouter />
    <meta content="width=device-width" name="viewport" />
    <link href="/favicon.ico" rel="icon" type="image/x-icon" />
    <meta content={Astro.generator} name="generator" />
    <title>{title}</title>
    <meta content={description} name="description" />
    <meta content="index, follow" name="robots" />
    <meta name="theme-color" content="#171717" />
    <meta name="author" content={SITE.author.fullName} />
    <meta
      name="keywords"
      content={`full stack developer, web developer, React, Astro, Solid.js, Svelte, freelance developer, ${SITE.location.countryName}, UX, animations, micro-interactions`}
    />
    <meta content="website" property="og:type" />
    <meta content={title} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content={Astro.url.origin} property="og:url" />
    <meta property="og:site_name" content={SITE.author.fullName} />
    <meta property="og:locale" content="en_US" />
    <meta
      content={image || `${Astro.url.origin}/og-image.png`}
      property="og:image"
    />
    <meta property="og:image:alt" content={description} />
    <meta property="og:image:type" content="image/png" />
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={title} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    <meta name="twitter:creator" content={`@${SITE.author.twitterHandle}`} />
    <meta
      content={image || `${Astro.url.origin}/og-image.png`}
      name="twitter:image"
    />

    <link href="https://cdn.fontshare.com" rel="preconnect" />

    <link href={Astro.url.href} rel="canonical" />
    <script
      is:inline
      set:html={JSON.stringify(schema)}
      type="application/ld+json"
    />
    <script
      defer
      is:inline
      src="https://cloud.umami.is/script.js"
      data-website-id={import.meta.env.UMAMI_WEBSITE_ID}></script>
    <script
      src="https://analytics.ahrefs.com/analytics.js"
      data-key={import.meta.env.AHREFS_ANALYTICS_KEY}
      async></script>

    <!-- Cal element-click embed code begins -->
    <script is:inline type="text/javascript">
      (function (C, A, L) {
        let p = function (a, ar) {
          a.q.push(ar);
        };
        let d = C.document;
        C.Cal =
          C.Cal ||
          function () {
            let cal = C.Cal;
            let ar = arguments;
            if (!cal.loaded) {
              cal.ns = {};
              cal.q = cal.q || [];
              d.head.appendChild(d.createElement("script")).src = A;
              cal.loaded = true;
            }
            if (ar[0] === L) {
              const api = function () {
                p(api, arguments);
              };
              const namespace = ar[1];
              api.q = api.q || [];
              if (typeof namespace === "string") {
                cal.ns[namespace] = cal.ns[namespace] || api;
                p(cal.ns[namespace], ar);
                p(cal, ["initNamespace", namespace]);
              } else p(cal, ar);
              return;
            }
            p(cal, ar);
          };
      })(window, "https://app.cal.com/embed/embed.js", "init");
      const calNamespace =
        document.documentElement.dataset.calNamespace || "15min";
      const calOrigin =
        document.documentElement.dataset.calOrigin || "https://cal.com";

      Cal("init", calNamespace, { origin: calOrigin });

      // Important: Please add the following attributes to the element that should trigger the calendar to open upon clicking.
      // `data-cal-link="ladvace/15min"`
      // data-cal-namespace="15min"
      // `data-cal-config='{"layout":"month_view"}'`

      Cal.ns[calNamespace]("ui", {
        styles: { branding: { brandColor: "#000000" } },
        hideEventTypeDetails: false,
        layout: "month_view",
      });
    </script>
    <!-- Cal element-click embed code ends -->
  </head>
  <body class="bg-darkslate-700 flex flex-col justify-center items-center">
    <slot name="loader" />
    <slot />
  </body>
</html>

<script>
  import {
    PORTFOLIO_HAS_VISITED_NON_HOME_KEY,
    PORTFOLIO_LAST_PATH_KEY,
    normalizePathname,
  } from "../lib/nav-path";

  if (typeof document !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      const theme = localStorage.getItem("theme");

      if (theme && theme !== "default") {
        document.body.classList.add(theme);
      }
    });

    document.addEventListener("astro:page-load", () => {
      const loader = document.querySelector(".loader");
      if (loader instanceof HTMLElement) {
        loader.style.opacity = "0";
        loader.style.pointerEvents = "none";
      }

      const path = normalizePathname(window.location.pathname);
      if (path !== "/") {
        sessionStorage.setItem(PORTFOLIO_HAS_VISITED_NON_HOME_KEY, "1");
      }

      queueMicrotask(() => {
        sessionStorage.setItem(PORTFOLIO_LAST_PATH_KEY, path);
      });
    });
  }
</script>

<style is:global>
  body {
    margin: 0;
    font-family: var(--font-satoshi), "Satoshi", sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: var(--font-cabinet-grotesk), "Cabinet Grotesk", sans-serif;
  }
  p {
    font-family: var(--font-satoshi), "Satoshi", sans-serif;
  }

  b {
    font-weight: 700 !important;
  }

  @supports (view-transition-name: none) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation-duration: 320ms;
      animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    }
  }
</style>
