<div id="grid-transition" aria-hidden="true" transition:persist></div>

<style is:global>
  #grid-transition {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    display: grid;
    background: #111111;
  }
</style>

<script>
  import gsap from "gsap";

  const CELL_SIZE = 50;
  const overlay = document.getElementById("grid-transition") as HTMLElement;
  let cells: HTMLElement[] = [];
  let gridCols = 0;
  let gridRows = 0;
  let phase = Math.random() * Math.PI * 2;

  function buildGrid() {
    gridCols = Math.ceil(window.innerWidth / CELL_SIZE) + 1;
    gridRows = Math.ceil(window.innerHeight / CELL_SIZE) + 1;
    overlay.style.gridTemplateColumns = `repeat(${gridCols}, 1fr)`;
    overlay.style.gridTemplateRows = `repeat(${gridRows}, 1fr)`;
    overlay.innerHTML = "";
    cells = Array.from({ length: gridCols * gridRows }, () => {
      const cell = document.createElement("div");
      overlay.appendChild(cell);
      return cell;
    });
  }

  function applyTheme() {
    const theme = localStorage.getItem("theme");
    document.body.classList.remove(
      "yellow-theme",
      "blue-theme",
      "purple-theme",
      "green-theme",
    );
    if (theme && theme !== "default") document.body.classList.add(theme);
    const portfolioStyle = localStorage.getItem("portfolioStyle");
    document.body.classList.remove("style-glass", "style-sharp", "style-neon", "style-paper");
    if (portfolioStyle && portfolioStyle !== "default")
      document.body.classList.add(portfolioStyle);
    const color = getComputedStyle(document.body)
      .getPropertyValue("--primary-500")
      .trim();
    cells.forEach((c) => (c.style.background = color));
    overlay.style.background = "transparent";
  }

  function cosNoise(nx: number, ny: number): number {
    return (
      Math.cos(nx * 6.2 + ny * 3.7 + phase) * 0.4 +
      Math.cos(nx * 2.1 - ny * 8.5 + phase * 1.3) * 0.35 +
      Math.cos(nx * 11.3 + ny * 1.9 + phase * 0.7) * 0.25 +
      Math.cos(nx * 24.7 + ny * 19.3 + phase * 1.7) * 0.15 +
      Math.cos(nx * 37.1 - ny * 31.6 + phase * 0.5) * 0.1
    );
  }

  function cellDelay(spread: number) {
    return (i: number): number => {
      const col = i % gridCols;
      const row = Math.floor(i / gridCols);
      const nx = col / Math.max(gridCols - 1, 1);
      const ny = row / Math.max(gridRows - 1, 1);
      const base = 1 - ny;
      const noise = cosNoise(nx, ny) * 0.22;
      const edgeFactor = 4 * base * (1 - base);
      const jitter = (Math.random() - 0.5) * 0.2 * edgeFactor;
      return Math.max(0, (base * 0.55 + noise + jitter) * spread);
    };
  }

  function cover(): Promise<void> {
    phase = Math.random() * Math.PI * 2;
    return new Promise((resolve) => {
      overlay.style.pointerEvents = "all";
      gsap.killTweensOf(cells);
      gsap.to(cells, {
        opacity: 1,
        duration: 0.2,
        stagger: cellDelay(0.35),
        ease: "steps(1)",
        onComplete: resolve,
      });
    });
  }

  function reveal(spread = 0.9): Promise<void> {
    phase = Math.random() * Math.PI * 2;
    applyTheme();
    document.dispatchEvent(new CustomEvent("grid:reveal-start"));
    return new Promise((resolve) => {
      gsap.killTweensOf(cells);
      gsap.to(cells, {
        opacity: 0,
        duration: 0.25,
        stagger: cellDelay(spread),
        ease: "steps(1)",
        onComplete: () => {
          overlay.style.pointerEvents = "none";
          document.dispatchEvent(new CustomEvent("grid:revealed"));
          resolve();
        },
      });
    });
  }

  // Initial page load
  buildGrid();
  applyTheme();
  gsap.set(cells, { opacity: 1 });
  reveal();

  document.addEventListener("astro:before-preparation", (e) => {
    const event = e as any;
    const originalLoader = event.loader;
    event.loader = () => Promise.all([cover(), originalLoader()]);
  });

  document.addEventListener("astro:after-swap", () => {
    reveal(0.35);
  });
</script>
