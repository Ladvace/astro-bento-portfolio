---
import { Icon } from "astro-icon/components";
import Content from "./Content.astro";

interface Props {
  title?: string;
  body?: string;
  colSpan?: string;
  rowSpan?: string;
  href?: string;
  colorText?: string;
  height?: string;
  width?: string;
  padding?: string;
  bgColor?: string;
  arrowCorner?: boolean;
  prefetch?: "hover" | "viewport" | "load" | "tap";
}

const {
  title,
  body,
  colSpan,
  rowSpan,
  href,
  colorText,
  height,
  padding,
  bgColor,
  arrowCorner,
  prefetch,
} = Astro.props;
---

<div
  class={`card group overflow-hidden transfor-y-[-40%] ${bgColor || "bg-darkslate-500"} shadow-lg rounded-lg border border-darkslate-400 hover:border-primary-500 align-start flex-none ${
    height || "h-full"
  } justify-start relative transform perspective-1200 w-full transition-all duration-300 ease-out col-span-1 ${
    colSpan || "md:col-span-2"
  } ${rowSpan || ""} ${padding || "p-6"}`}
>
  <slot name="background" />
  {
    href ? (
      <a
        class={`h-full w-full flex flex-col justify-start relative ${colorText || ""}`}
        href={href}
        data-astro-prefetch={prefetch}
      >
        <Icon
          class={`h-5 w-5 absolute right-0 group-hover:text-primary-500 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform ease-in-out duration-100 z-20 flex-shrink-0 ${arrowCorner ? "top-0" : "inset-y-0 my-auto"}`}
          name="ri:arrow-right-up-line"
        />
        <Content body={body} title={title}>
          <slot />
        </Content>
      </a>
    ) : (
      <Content body={body} title={title}>
        <slot />
      </Content>
    )
  }
</div>
