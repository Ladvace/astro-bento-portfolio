---
import Card from "./Card/index.astro";
import { Image } from "astro:assets";
import { illustrationsRow1, illustrationsRow2 } from "../lib/illustrations";
---

<Card
  colSpan="lg:col-span-1"
  rowSpan="md:row-span-1"
  title="Design Works"
  href="/design-works"
>
  <div
    slot="background"
    class="absolute inset-0 -z-10 overflow-hidden flex flex-col justify-center gap-2 opacity-30"
  >
    <!-- fade edges -->
    <div
      class="absolute inset-y-0 left-0 w-10 z-10 bg-gradient-to-r from-darkslate-500 to-transparent pointer-events-none"
    >
    </div>
    <div
      class="absolute inset-y-0 right-0 w-10 z-10 bg-gradient-to-l from-darkslate-500 to-transparent pointer-events-none"
    >
    </div>

    <!-- row 1: left -->
    <div class="flex gap-2 marquee-left">
      {
        [...illustrationsRow1, ...illustrationsRow1].map(({ src, alt }) => (
          <Image
            src={src}
            class="w-14 h-14 rounded-lg object-cover flex-shrink-0"
            alt={alt}
            loading="eager"
            decoding="auto"
          />
        ))
      }
    </div>

    <!-- row 2: right -->
    <div class="flex gap-2 marquee-right">
      {
        [...illustrationsRow2, ...illustrationsRow2].map(({ src, alt }) => (
          <Image
            src={src}
            class="w-14 h-14 rounded-lg object-cover flex-shrink-0"
            alt={alt}
            loading="eager"
            decoding="auto"
          />
        ))
      }
    </div>
  </div>
</Card>

<style>
  @keyframes marquee-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  @keyframes marquee-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }
  .marquee-left {
    animation: marquee-left 18s linear infinite;
  }
  .marquee-right {
    animation: marquee-right 14s linear infinite;
  }
</style>
